{
  "buildCommand": null,
  "outputDirectory": ".",
  "installCommand": null,
  "framework": null,
  "rewrites": [
    { "source": "/shop", "destination": "/public/shop.html" },
    { "source": "/benefits", "destination": "/public/benefits.html" },
    { "source": "/story", "destination": "/public/story.html" },
    { "source": "/reviews", "destination": "/public/reviews.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
